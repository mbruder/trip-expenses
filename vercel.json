{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.supabase.co https://api.anthropic.com https://fonts.googleapis.com https://fonts.gstatic.com"
        }
      ]
    }
  ]
}
